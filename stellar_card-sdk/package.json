{
  "name": "stellar_card",
  "version": "0.4.7",
  "description": "Virtual Visa cards for AI agents — pay USDC or XLM on Stellar, get a card in ~60s",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.js"
    }
  },
  "sideEffects": false,
  "browser": {
    "./dist/config.js": false,
    "./dist/ows.js": false,
    "./dist/cli.js": false,
    "./dist/commands/onboard.js": false,
    "./dist/commands/purchase.js": false,
    "./dist/commands/wallet.js": false,
    "fs": false,
    "path": false,
    "os": false,
    "crypto": false
  },
  "bin": {
    "stellar_card": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "stellar",
    "usdc",
    "xlm",
    "virtual-card",
    "vcc",
    "visa",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "402-payment",
    "soroban",
    "stellar_card"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CTX-com/Stellar_Card"
  },
  "homepage": "https://stellar_card.com",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "axios": "^1.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@ctx.com/stellar-ows-core": "^1.3.0-stellar",
    "@stellar/stellar-sdk": "^15.0.1"
  },
  "optionalDependencies": {
    "@ctx.com/stellar-ows-core-linux-x64-gnu": "1.3.0-stellar",
    "@ctx.com/stellar-ows-core-linux-arm64-gnu": "1.3.0-stellar",
    "@ctx.com/stellar-ows-core-darwin-x64": "1.3.0-stellar",
    "@ctx.com/stellar-ows-core-darwin-arm64": "1.3.0-stellar"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
