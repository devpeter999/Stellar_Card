# =============================================================================
# stellar_card backend — environment variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development

# Database
DB_PATH=./stellar_card.db

# Stellar — treasury wallet used for USDC/XLM refunds to agents
STELLAR_NETWORK=mainnet
STELLAR_USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
STELLAR_XLM_SECRET=S...           # Treasury secret key

# Soroban receiver contract — accepts USDC from agents on-chain
RECEIVER_CONTRACT_ID=C...         # Contract ID from `stellar contract deploy` output
# SOROBAN_RPC_URL=                # Optional: override default RPC URL

# VCC fulfillment service (vcc.ctx.com) — handles CTX ordering + card scraping
VCC_API_BASE=https://vcc.ctx.com
# Public base URL of this stellar_card instance (used to construct the VCC callback URL)
CARDS402_BASE_URL=https://api.stellar_card.com
# Secret for verifying HMAC-signed callbacks from VCC — generate with: openssl rand -hex 32
VCC_CALLBACK_SECRET=

# CORS — comma-separated allowed origins for the agent API (optional)
# CORS_ORIGINS=https://stellar_card.com,https://app.stellar_card.com

# Bootstrap owner — only this email can claim owner role on a fresh instance (optional)
# Leave unset for local dev (first verifier becomes owner)
# OWNER_EMAIL=owner@example.com

# Internal dashboard access — comma-separated emails allowed to access /internal/* routes
# Emails ending in @stellar_card.com are always allowed regardless of this setting
# INTERNAL_EMAILS=ops@example.com,eng@example.com
